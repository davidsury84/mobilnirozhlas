# Zkopíruj tento soubor na ".env" a vyplň hodnoty. Soubor .env je v .gitignore (necommituje se).

# --- Přihlášení do správy (volitelné; jinak se heslo vygeneruje a vypíše do konzole) ---
# ADMIN_PASSWORD=zvol-silne-heslo

# --- Intranet zaměstnanců: přihlášení přes Google (OIDC) ---
# Vytvoř v Google Cloud Console → APIs & Services → Credentials → OAuth client ID (Web application).
# Authorized redirect URI musí PŘESNĚ odpovídat:
#   lokálně:   http://localhost:8080/auth/google/callback
#   produkce:  https://intranet.elkoplast.cz/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Omezení přihlášení jen na firemní doménu (doporučeno pro produkci).
# Pro první test s osobním Gmailem nech prázdné.
ALLOWED_HD=elkoplast.cz

# Veřejná adresa (pro odkazy v e-mailech a redirect URI v produkci).
# Lokálně nech prázdné – odvodí se http://localhost:8080.
# PUBLIC_URL=https://intranet.elkoplast.cz

# --- Měsíční vyhodnocení (e-mailem) ---
# Jednou měsíčně se odešle souhrn stavu seznámení. Vyžaduje nastavenou poštu (SMTP nebo RESEND_API_KEY).
REPORT_EMAIL=tomas.krajca@elkoplast.cz
# REPORT_DAY=1          # den v měsíci (1–28)
# REPORT_ENABLED=0      # nastav na 0 pro vypnutí

# --- Dovolená → Google Calendar (volitelné) ---
# Po schválení dovolené se automaticky vytvoří událost ve sdíleném kalendáři „Dovolené".
# 1) V Google Cloud Console vytvoř Service Account, povol Google Calendar API a stáhni JSON klíč.
# 2) Sdílený kalendář „Dovolené" nasdílej na e-mail service accountu s právem „Provádět změny v událostech".
# 3) Sem doplň ID kalendáře (Nastavení kalendáře → Integrace kalendáře → ID kalendáře),
#    client_email a private_key ze staženého JSON (nové řádky v klíči zapiš jako \n).
# VACATION_CALENDAR_ID=xxxxxxxx@group.calendar.google.com
# GOOGLE_SA_CLIENT_EMAIL=dovolena@projekt.iam.gserviceaccount.com
# GOOGLE_SA_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n

# --- Ostatní (volitelné) ---
# PORT=8080
# DATA_DIR=./data
# RESEND_API_KEY=
# RESEND_FROM=onboarding@resend.dev

# --- Modul Adaptace (onboarding) ---
# Token pro import zaměstnance z náboru: POST /api/adaptace/import-user (hlavička X-Api-Token).
# ADAPTACE_API_TOKEN=
